# ============================================
# Sport Data Solution — Variables d'environnement
# ============================================

# --- GCP ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west1
GCS_BUCKET_NAME=sport-data-solution-raw
GOOGLE_APPLICATION_CREDENTIALS=./secrets/gcp-key.json

# --- BigQuery ---
BQ_DATASET_BRONZE=sport_bronze
BQ_DATASET_SILVER=sport_silver
BQ_DATASET_GOLD=sport_gold

# --- Google Maps API ---
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
COMPANY_ADDRESS=1362 Av. des Platanes, 34970 Lattes

# --- Slack ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
SLACK_CHANNEL=#sport-avantages

# --- Airflow ---
AIRFLOW__CORE__FERNET_KEY=your-fernet-key
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow

# --- PySpark ---
SPARK_MASTER=local[*]
STRAVA_SIMULATION_MONTHS=12
STRAVA_SIMULATION_MIN_ROWS=5000
